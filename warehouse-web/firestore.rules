rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // AUTH HELPERS
    // ============================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function myProfileExists() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function myRole() {
      return myProfileExists() ? me().data.role : null;
    }

    function myBrands() {
      return (myProfileExists() && me().data.brands is list) ? me().data.brands : [];
    }

    function isManagerRole() {
      return myRole() in ['manager', 'sales_manager'];
    }

    function isExpenseApproverRole() {
      return isManagerRole() || isAdmin();
    }

    function brandIsAccessible(brand) {
      return brand == null || brand in myBrands();
    }

    function isAdmin() {
      return myRole() in ['owner', 'admin', 'developer'];
    }

    // Optional: query-safe admin check via Auth custom claims.
    // If you set a custom claim like { role: 'admin' } on the user, rules can
    // allow privileged list queries without any Firestore get()/exists() lookups.
    function isAdminClaim() {
      return isSignedIn()
        && (request.auth.token.role is string)
        && (request.auth.token.role in ['owner', 'admin', 'developer']);
    }

    function isAdminForBrand(brand) {
      return isAdmin() && brandIsAccessible(brand);
    }

    function isWarehouseManagerForBrand(brand) {
      return myRole() == 'warehouse_manager'
        && brand != null
        && brandIsAccessible(brand);
    }

      function hasFieldSalesBrandAccess(data) {
        return data.brand is string && brandIsAccessible(data.brand);
      }

      function isFieldSalesPrivilegedUser() {
        return isManagerRole() || isAdmin();
      }

      function isOwnFieldSalesSalesmanDoc(data) {
        return data.salesmanId is string && data.salesmanId == request.auth.uid;
      }

      function canReadSalesmanScopedFieldSalesDoc(data) {
        return isSignedIn()
          && hasFieldSalesBrandAccess(data)
          && (isFieldSalesPrivilegedUser() || isOwnFieldSalesSalesmanDoc(data));
      }

      function canCreateSalesmanScopedFieldSalesDoc(data) {
        return isSignedIn()
          && hasFieldSalesBrandAccess(data)
          && (isFieldSalesPrivilegedUser() || isOwnFieldSalesSalesmanDoc(data));
      }

      function canUpdateSalesmanScopedFieldSalesDoc(newData, existingData) {
        return isSignedIn()
          && hasFieldSalesBrandAccess(newData)
          && hasFieldSalesBrandAccess(existingData)
          && (
            isFieldSalesPrivilegedUser()
            || (isOwnFieldSalesSalesmanDoc(existingData) && isOwnFieldSalesSalesmanDoc(newData))
          );
      }

    function isOrderOwner(order) {
      return isSignedIn() && order.userId == request.auth.uid;
    }

    function brandOrNull(order) {
      return order.brand == null ? null : order.brand;
    }

    function orderCreator(order) {
      return order.createdBy == null ? order.userId : order.createdBy;
    }

    function canReadOrder(order) {
      let brand = brandOrNull(order);
      return isOrderOwner(order)
        || isAdminForBrand(brand)
        || isWarehouseManagerForBrand(brand);
    }

    function canCreateOrder(data) {
      let brand = brandOrNull(data);
      let creator = orderCreator(data);

      let ownerGuard =
        isSignedIn() &&
        creator == request.auth.uid &&
        brandIsAccessible(brand);

      return ownerGuard || isAdminForBrand(brand);
    }

    function canUpdateOrder(newData, existing) {
      let newBrand       = brandOrNull(newData);
      let currentBrand   = brandOrNull(existing);
      let creatorPreserved = orderCreator(newData) == orderCreator(existing);

      let ownerGuard =
        isOrderOwner(existing) &&
        newData.userId == existing.userId &&
        creatorPreserved &&
        brandIsAccessible(newBrand) &&
        brandIsAccessible(currentBrand);

      let adminGuard =
        isAdminForBrand(newBrand) &&
        isAdminForBrand(currentBrand);

      let warehouseKivosGuard =
        newBrand == 'kivos' &&
        currentBrand == 'kivos' &&
        isWarehouseManagerForBrand('kivos');

      return ownerGuard || adminGuard || warehouseKivosGuard;
    }

    function canDeleteOrder(order) {
      let brand = brandOrNull(order);
      return isOrderOwner(order)
        || isAdminForBrand(brand)
        || (brand == 'kivos' && isWarehouseManagerForBrand('kivos'));
    }

    // ============================================================
    // NEW: WEB DASHBOARD ACCESS FOR KIVOS WAREHOUSE MANAGER
    // ============================================================

    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // IMPORTANT: pure expression, no "if" statements
    function isKivosWarehouseUser() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userProfile().data.role in ['warehouse_manager', 'owner', 'admin']
        && userProfile().data.brands is list
        && userProfile().data.brands.hasAny(['kivos']);
    }

    // ============================================================
    // USERS
    // ============================================================

    match /users/{uid} {
      // Managers can read assigned salesmen (via users/{salesmanId}.managers)
      allow read: if isSignedIn() && (
        request.auth.uid == uid
        || isAdmin()
        || (isManagerRole() && (resource.data.managers is list) && (request.auth.uid in resource.data.managers))
      );
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow delete: if isAdmin();
    }

    // ============================================================
    // PRODUCTS
    // ============================================================

    match /products/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /products_john/{docId} {
      allow read: if isSignedIn() && brandIsAccessible('john');
      allow write: if isAdminForBrand('john');
    }

    match /products_kivos/{docId} {
      allow read: if isSignedIn() && brandIsAccessible('kivos');
      allow write: if isAdminForBrand('kivos') || isWarehouseManagerForBrand('kivos');
    }

    // ============================================================
    // STOCK (KIVOS)
    // ============================================================

    match /stock_kivos/{docId} {
      allow read: if isAdminForBrand('kivos') || isWarehouseManagerForBrand('kivos');
      allow write: if isAdminForBrand('kivos') || isWarehouseManagerForBrand('kivos');
    }

    // ============================================================
    // MERGED — FINAL CORRECT RULE FOR stock_kivos_history
    //
    // ✔ Read allowed for warehouse dashboard users AND Kivos admin/warehouse managers
    // ✔ Create allowed for admins + warehouse managers (original rule)
    // ✔ Covers nested paths via {docId=**}
    // ============================================================

    match /stock_kivos_history/{docId=**} {
      // READ: dashboard and Kivos brand admins/managers
      allow read: if isKivosWarehouseUser()
        || isAdminForBrand('kivos')
        || isWarehouseManagerForBrand('kivos');

      // CREATE: same as original logic
      allow create: if request.auth != null
        && (isAdminForBrand('kivos') || isWarehouseManagerForBrand('kivos'))
        && request.resource.data.keys().hasAll([
             'productCode',
             'oldQty',
             'newQty',
             'delta',
             'updatedBy',
             'timestamp'
           ]);
    }

    // ============================================================
    // CUSTOMERS
    // ============================================================

    match /customers/{docId} {
      allow read: if isSignedIn();
      // Field users must be able to register new customers directly from the app.
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /customers_john/{docId} {
      allow read: if isSignedIn() && brandIsAccessible('john');
      // Allow signed-in app users to add or update customer records for John.
      allow create, update: if isSignedIn();
      allow delete: if isAdminForBrand('john');
    }

    match /customers_kivos/{docId} {
      allow read: if isSignedIn() && brandIsAccessible('kivos');
      // Allow signed-in app users to add or update customer records for Kivos.
      allow create, update: if isSignedIn();
      allow delete: if isAdminForBrand('kivos') || isWarehouseManagerForBrand('kivos');
    }

    // ============================================================
    // FIELD SALES PRO (M1)
    // ============================================================

    match /territories/{docId} {
      allow read: if isSignedIn()
        && resource.data.brand is string
        && brandIsAccessible(resource.data.brand);

      allow create, update: if isSignedIn()
        && isManagerRole()
        && request.resource.data.brand is string
        && brandIsAccessible(request.resource.data.brand);

      allow delete: if isSignedIn()
        && isAdmin()
        && resource.data.brand is string
        && brandIsAccessible(resource.data.brand);
    }

    match /territoryAssignments/{docId} {
      allow read: if isSignedIn()
        && resource.data.brand is string
        && brandIsAccessible(resource.data.brand);

      allow create, update: if isSignedIn()
        && isManagerRole()
        && request.resource.data.brand is string
        && brandIsAccessible(request.resource.data.brand);

      allow delete: if isSignedIn()
        && isAdmin()
        && resource.data.brand is string
        && brandIsAccessible(resource.data.brand);
    }

    match /visitPlans/{docId} {
      allow read: if canReadSalesmanScopedFieldSalesDoc(resource.data);

      allow create: if canCreateSalesmanScopedFieldSalesDoc(request.resource.data);

      allow update: if canUpdateSalesmanScopedFieldSalesDoc(request.resource.data, resource.data);

      allow delete: if false;
    }

    match /visitExecutions/{docId} {
      allow read: if canReadSalesmanScopedFieldSalesDoc(resource.data);

      allow create: if canCreateSalesmanScopedFieldSalesDoc(request.resource.data);

      allow update: if canUpdateSalesmanScopedFieldSalesDoc(request.resource.data, resource.data);

      allow delete: if false;
    }

    match /schedules/{docId} {
      allow read: if canReadSalesmanScopedFieldSalesDoc(resource.data);

      allow create: if isSignedIn()
        && isFieldSalesPrivilegedUser()
        && hasFieldSalesBrandAccess(request.resource.data);

      allow update: if isSignedIn()
        && isFieldSalesPrivilegedUser()
        && hasFieldSalesBrandAccess(request.resource.data)
        && hasFieldSalesBrandAccess(resource.data);

      allow delete: if false;
    }

    // ============================================================
    // IMAGES & SALESMEN
    // ============================================================

    match /images/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /salesmen/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ============================================================
    // EXPENSE TRACKER - EXPENSES, CARS, FUEL TYPES, SERVICE TYPES
    // ============================================================

    match /expenses/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
      
      match /records/{expenseId} {
        // Salesman can read/create/update/delete own expenses
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && request.auth.uid == userId;
        allow update: if isSignedIn() && request.auth.uid == userId;
        allow delete: if isSignedIn() && request.auth.uid == userId;
        
        // Managers can read, update, and delete all expenses
        allow read: if isSignedIn() && isExpenseApproverRole();
        allow update: if isSignedIn() && isExpenseApproverRole();
        allow delete: if isSignedIn() && isExpenseApproverRole();
      }
    }

    match /cars/{carId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /carBrands/{brandId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /fuelTypes/{fuelTypeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /serviceTypes/{serviceTypeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ============================================================
    // EXPENSE TRACKER - WEEKLY TRACKING
    // Path: weeklyTracking/{userId}/weeks/{weekId}
    // ============================================================

    match /weeklyTracking/{userId} {
      match /weeks/{weekId} {
        // Salesman can read/write own weekly tracking
        allow read, create, update, delete: if isSignedIn() && request.auth.uid == userId;

        // Managers can read weekly tracking (for reporting)
        allow read: if isSignedIn() && isExpenseApproverRole();

        // Managers can update weekly tracking status (approval flow)
        allow update: if isSignedIn() && isExpenseApproverRole();
      }
    }

    // ============================================================
    // EXPENSE TRACKER - WEEKLY REPORT SUBMISSIONS (INBOX)
    // Path: weeklyReportSubmissions/{salesmanId}_{weekId}
    // ============================================================

    match /weeklyReportSubmissions/{submissionId} {
      // IMPORTANT:
      // - allow get broadly so printing a DRAFT week (no submission doc yet) returns "not found"
      //   instead of PERMISSION_DENIED.
      // - keep list/update in a query-analyzable form so queries like:
      //   where('managerIds','array-contains', request.auth.uid)
      //   are allowed.
      allow get: if isSignedIn();

      // NOTE: For collection queries, avoid depending on user-profile lookups (get/exists)
      // because it can make the query non-queryable and fail with PERMISSION_DENIED.
      allow list: if isSignedIn() && (
        isAdminClaim()
        || resource.data.managerIds.hasAny([request.auth.uid])
      );

      // Create allowed for the salesman creating their own submission
      allow create: if isSignedIn()
        && request.resource.data.salesmanId == request.auth.uid
        && request.resource.data.weekId is string
        && submissionId == (request.auth.uid + '_' + request.resource.data.weekId)
        && request.resource.data.managerIds is list;

      // Updates allowed for:
      // - salesman (e.g., resubmit/merge)
      // - manager in managerIds (approve)
      allow update: if isSignedIn() && (
        isAdminClaim()
        || (resource.data.salesmanId == request.auth.uid)
        || ((resource.data.managerIds is list) && resource.data.managerIds.hasAny([request.auth.uid]))
      );

      // Delete not needed in app flow
      allow delete: if false;
    }

    // ============================================================
    // EXPENSE TRACKER - WEEKLY REPORT SERIES (YEARLY COUNTERS)
    // Path: weeklyReportSeries/{managerId}_{year}
    // ============================================================

    match /weeklyReportSeries/{docId} {
      allow read, write: if isSignedIn() && isExpenseApproverRole();
    }

    // ============================================================
    // BRAND CONTACTS
    // ============================================================

    match /brand_contacts/{docId} {
      allow read: if isSignedIn() &&
        (!('brand' in resource.data) || brandIsAccessible(resource.data.brand));
      allow write: if isAdmin();
    }

    // ============================================================
    // SUPERMARKETS
    // ============================================================

    match /supermarket_stores/{docId} {
      allow read: if isSignedIn() && myBrands().size() > 0;
      allow write: if isAdmin();
    }

    match /supermarket_listings/{docId} {
      allow read: if isSignedIn() && myBrands().size() > 0;
      allow write: if isAdmin();
    }

    match /supermarket_meta/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ============================================================
    // KPI DASHBOARD
    // ============================================================

    match /sheetsCache/{sheetId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // ============================================================
    // ORDERS
    // ============================================================

    match /orders/{orderId} {
      allow read: if canReadOrder(resource.data);
      allow create: if canCreateOrder(request.resource.data);
      allow update: if canUpdateOrder(request.resource.data, resource.data);
      allow delete: if canDeleteOrder(resource.data);
    }

    match /orders_john/{orderId} {
      allow read: if canReadOrder(resource.data);
      allow create: if canCreateOrder(request.resource.data);
      allow update: if canUpdateOrder(request.resource.data, resource.data);
      allow delete: if canDeleteOrder(resource.data);
    }

    match /orders_kivos/{orderId} {
      allow read: if canReadOrder(resource.data) || isWarehouseManagerForBrand('kivos');
      allow create: if canCreateOrder(request.resource.data) || isWarehouseManagerForBrand('kivos');
      allow update: if canUpdateOrder(request.resource.data, resource.data);
      allow delete: if canDeleteOrder(resource.data);
    }

    match /orders_playmobil_supermarket/{orderId} {
      allow read: if canReadOrder(resource.data);
      allow create: if canCreateOrder(request.resource.data);
      allow update: if canUpdateOrder(request.resource.data, resource.data);
      allow delete: if canDeleteOrder(resource.data);
    }

    match /orders_john_supermarket/{orderId} {
      allow read: if canReadOrder(resource.data);
      allow create: if canCreateOrder(request.resource.data);
      allow update: if canUpdateOrder(request.resource.data, resource.data);
      allow delete: if canDeleteOrder(resource.data);
    }

    // ============================================================
    // SUPPLIER ORDERS (KIVOS)
    // ============================================================

    match /supplier_orders_kivos/{docId} {
      allow read, create, update: if isAdminForBrand('kivos') || isWarehouseManagerForBrand('kivos');
      allow delete: if isAdminForBrand('kivos');
    }

    // ============================================================
    // INVENTORY COUNTS (KIVOS)
    // ============================================================

    match /inventory_counts_kivos/{docId} {
      allow read: if isAdminForBrand('kivos') || isWarehouseManagerForBrand('kivos');
      allow create: if isAdminForBrand('kivos') || isWarehouseManagerForBrand('kivos');
      allow update: if isAdminForBrand('kivos');
      allow delete: if isAdminForBrand('kivos');
    }

    // ============================================================
    // DEFAULT DENY (MUST BE LAST)
    // ============================================================

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
